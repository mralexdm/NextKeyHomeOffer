---
import { site, nav, cities, situations } from '../data/site.js';
import MapEmbed from './MapEmbed.astro';
const year = 2026;
const addr = site.address;
const napLine = [addr.streetAddress, `${addr.locality}, ${addr.region}`, addr.postalCode].filter(Boolean).join(' · ');
---
<footer class="foot" id="service-area">
  <div class="wrap">
    <div class="foot__cols">
      <div class="foot__col foot__brand">
        <a class="brand" href="/" aria-label={`${site.name} home`}>
          <img class="brand__mark" src="/assets/logo-badge.svg" alt="" width="34" height="34" />
          <span class="brand__txt">
            <span class="brand__name">NEXTKEY</span>
            <span class="brand__sub">Home Offer</span>
          </span>
        </a>
        <p>Locally owned cash home buyers serving Fremont, the South Bay, and the East Bay. We buy as-is, charge no fees, and close on your timeline.</p>
        <a class="foot__contact-link" href={site.phoneHref} data-track="call" style="display:inline-flex;align-items:center;gap:8px;color:var(--on-dark);font-weight:600;text-decoration:none;margin-bottom:8px">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="var(--flare)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
          {site.phone}
        </a>
        <p class="foot__hours">{site.hours}. Call or text any time.</p>
        <p class="foot__hours">{napLine}</p>
      </div>

      <div class="foot__col">
        <h4>Explore</h4>
        <a href="/">Home</a>
        {nav.filter((n) => n.href !== '/areas-we-serve').map((n) => <a href={n.href}>{n.label}</a>)}
      </div>

      <div class="foot__col">
        <h4>Areas we serve</h4>
        <a href="/areas-we-serve">All areas</a>
        {cities.map((c) => <a href={`/areas-we-serve/${c.slug}`}>{c.name}</a>)}
      </div>

      <div class="foot__col">
        <h4>We help with</h4>
        {situations.map((s) => <a href={s.href}>{s.label}</a>)}
      </div>
    </div>

    <div class="foot__map">
      <MapEmbed title={`${site.name} — service area map`} />
    </div>

    <div class="foot__legal">
      <div><a href="/privacy">Privacy Policy</a><a href="/terms">Terms</a></div>
      <div>&copy; {year} {site.name} · {addr.locality}, {addr.region}</div>
    </div>
    <p class="foot__disc">{site.name} is a local home-buying company, not a licensed real estate brokerage, and does not provide real estate, legal, or tax advice. We buy houses directly as a principal. Cash offers are made in writing and carry no obligation. We charge no fees or commissions. Closing timelines depend on title and property specifics.</p>
  </div>
</footer>
