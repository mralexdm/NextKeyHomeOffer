---
import { site, nav } from '../data/site.js';
const { offerHref = '#offer' } = Astro.props;
const current = (Astro.url.pathname.replace(/\/$/, '') || '/');
const isCurrent = (href) =>
  href === '/' ? current === '/' : current === href || current.startsWith(href + '/');
---
<header class="hdr">
  <div class="hdr__in">
    <a class="brand" href="/" aria-label={`${site.name} home`}>
      <span class="brand__txt">
        <span class="brand__name">NEXTKEY</span>
        <span class="brand__sub">Home Offer</span>
      </span>
    </a>

    <nav class="nav" aria-label="Primary">
      {nav.map((item) => (
        <a class="nav__link" href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>{item.label}</a>
      ))}
    </nav>

    <div class="hdr__cta">
      <a class="hdr__phone" href={site.phoneHref} aria-label={`Call or text ${site.name} at ${site.phone}`} data-track="call">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
        <span>{site.phone}</span>
      </a>
      <a class="btn btn--primary" href={offerHref}>Get my offer</a>
      <button class="hdr__toggle" type="button" data-drawer-open aria-label="Open menu" aria-expanded="false" aria-controls="nav-drawer">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>
</header>

<!-- MOBILE DRAWER -->
<div class="drawer" id="nav-drawer">
  <div class="drawer__scrim" data-drawer-close></div>
  <div class="drawer__panel" role="dialog" aria-modal="true" aria-label="Site menu">
    <div class="drawer__head">
      <span class="brand__txt">
        <span class="brand__name">NEXTKEY</span>
        <span class="brand__sub">Home Offer</span>
      </span>
      <button class="drawer__close" type="button" data-drawer-close aria-label="Close menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <a class="drawer__link" href="/" aria-current={current === '/' ? 'page' : undefined}>Home</a>
    {nav.map((item) => (
      <a class="drawer__link" href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined} data-drawer-close>{item.label}</a>
    ))}
    <a class="drawer__phone" href={site.phoneHref} data-track="call">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
      {site.phone}
    </a>
    <a class="btn btn--primary btn--block drawer__cta" href={offerHref} data-drawer-close>Get my cash offer</a>
  </div>
</div>

<script>
  const toggle = document.querySelector('[data-drawer-open]');
  const drawer = document.getElementById('nav-drawer');
  if (toggle && drawer) {
    const open = () => { drawer.classList.add('is-open'); document.body.style.overflow = 'hidden'; toggle.setAttribute('aria-expanded', 'true'); };
    const close = () => { drawer.classList.remove('is-open'); document.body.style.overflow = ''; toggle.setAttribute('aria-expanded', 'false'); };
    toggle.addEventListener('click', open);
    drawer.querySelectorAll('[data-drawer-close]').forEach((el) => el.addEventListener('click', close));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && drawer.classList.contains('is-open')) close(); });
  }
</script>
