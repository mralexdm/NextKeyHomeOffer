---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import OfferBand from '../components/OfferBand.astro';
import Reviews from '../components/Reviews.astro';
import LeadForm from '../components/LeadForm.astro';
import { site } from '../data/site.js';
import { coreFaqs } from '../data/faqs.js';
import { serviceSchema, faqSchema } from '../lib/schema.js';

const title = 'Sell My House Fast in Fremont & the Bay Area | NextKey Home Offer';
const description = 'Sell my house fast in Fremont and the Bay Area. Get a fair cash offer in 24 hours, sell as-is, pay no fees or commissions, and pick your own closing date. Call or text (408) 314-4420.';

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Sell My House Fast', path: '/sell-my-house-fast' },
];
---
<Base title={title} description={description}
  schema={[
    serviceSchema({
      name: 'Sell Your House As-Is for Cash',
      description: 'We buy Bay Area houses as-is for cash — no repairs, no fees, no showings — and close on your timeline.',
    }),
    faqSchema(coreFaqs),
  ]}
  ogTitle="Sell My House Fast for Cash in Fremont & the Bay Area | NextKey Home Offer"
  ogDescription="A real cash offer in 24 hours. Sell as-is, pay no fees, and pick your own closing date across Fremont and the East Bay.">

  <!-- HERO: form above the fold -->
  <section class="band band--dark">
    <div class="wrap">
      <div class="split">
        <div>
          <span class="eyebrow" style="color:var(--flare);display:block;margin-bottom:14px">Fremont &amp; the Bay Area · Cash Home Buyers</span>
          <h1>Sell My House Fast in Fremont &amp; the Bay Area</h1>
          <p style="color:var(--muted-dark);font-size:1.08rem;max-width:52ch;margin-bottom:20px">Skip the listing, the repairs, and the months of waiting. Tell us about your house and get a real, no-obligation cash offer in 24 hours. We buy with our own funds, so the number we send is the number you get.</p>
          <div class="chips">
            <span class="chip"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Cash offer in 24 hrs</span>
            <span class="chip"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>No fees or commissions</span>
            <span class="chip"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>Sell as-is</span>
            <span class="chip"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>You pick the close date</span>
          </div>
          <p style="margin-top:20px;color:var(--muted-dark)">Prefer to talk? <a href={site.phoneHref} data-track="call" style="color:var(--flare);font-weight:600;text-decoration:none">Call or text {site.phone}</a>.</p>
        </div>
        <LeadForm id="offer-hero" source="NextKey Site - Sell My House Fast" />
      </div>
    </div>
  </section>

  <Breadcrumbs items={crumbs} />

  <!-- WHY NEXTKEY BEATS LISTING -->
  <section class="band band--cream">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow">Why selling to NextKey beats listing</span>
        <h2>A faster, cleaner way to sell your Bay Area house</h2>
        <p>Listing on the open market means repairs, showings, inspections, financing that can fall through, and up to <span style="color:var(--ember);font-weight:600;">8 percent in commissions and costs</span>. We skip all of it and pay cash. Here is what that looks like.</p>
      </div>
      <div class="grid grid--3">
        <article class="card">
          <div class="card__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
          <h3>No commissions</h3>
          <p>No agent's 6 percent and no listing fees. You keep the full offer, and we cover standard closing costs.</p>
        </article>
        <article class="card">
          <div class="card__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></div>
          <h3>No repairs</h3>
          <p>Old roof, dated kitchen, deferred maintenance. Leave it. We buy as-is and handle the cleanup and repairs ourselves.</p>
        </article>
        <article class="card">
          <div class="card__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.94 17.94A10 10 0 0 1 12 20c-7 0-11-8-11-8a18.5 18.5 0 0 1 5.06-5.94M9.9 4.24A9 9 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg></div>
          <h3>No showings</h3>
          <p>No open houses, no lockbox, no strangers walking through your kitchen. One walkthrough with us is all it takes.</p>
        </article>
        <article class="card">
          <div class="card__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><polyline points="9 11.5 11.5 14 15.5 9.5"/></svg></div>
          <h3>Certainty of cash</h3>
          <p>No bank, no appraisal, no financing contingency. We buy with our own funds, so the deal does not fall through at the last minute. Proof of funds on request.</p>
        </article>
        <article class="card">
          <div class="card__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/></svg></div>
          <h3>Real speed</h3>
          <p>Most offers go out within 24 hours, and we can close in as few as 7 days. No 60-day escrow drama.</p>
        </article>
        <article class="card">
          <div class="card__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
          <h3>Your timeline</h3>
          <p>Need to close next week? Done. Need 90 days to find your next place? Also done. You pick the date that fits your life.</p>
        </article>
      </div>
      <p class="sits-note">We close at a reputable local title company, so a licensed professional handles the paperwork and the money is real. Want the full walkthrough? <a href="/how-it-works">See how it works &rarr;</a></p>
    </div>
  </section>

  <!-- HOW IT WORKS (condensed) -->
  <section class="band band--dark">
    <div class="wrap">
      <div class="sec-head center">
        <span class="eyebrow">How it works</span>
        <h2>Three steps. No realtor required.</h2>
      </div>
      <div class="steps">
        <div class="step">
          <div class="step__n">Step 01</div>
          <h3>Tell us about your house</h3>
          <p>Share the address and a few details by form, phone, or text. It takes about two minutes, with no cost and no obligation.</p>
        </div>
        <div class="step">
          <div class="step__n">Step 02</div>
          <h3>Get your cash offer in 24 hours</h3>
          <p>We review recent Bay Area sales and your home's condition, then send a real, written cash offer, typically within one business day.</p>
        </div>
        <div class="step">
          <div class="step__n">Step 03</div>
          <h3>Pick your date and get paid</h3>
          <p>Choose any closing date that works for you. We close at a local title company and you walk away with cash in hand.</p>
        </div>
      </div>
      <div class="steps-cta"><a class="btn btn--primary btn--lg" href="#offer">Start with your address</a> <a class="btn btn--ghost btn--lg" href="/how-it-works">See the full process</a></div>
    </div>
  </section>

  <!-- SITUATIONS -->
  <section class="band band--cream">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow">Situations we buy through</span>
        <h2>Whatever is making you sell, we have handled it</h2>
        <p>People call us when listing with an agent isn't the right fit. Maybe there's no time, no money for repairs, or you're just done with the hassle. These are the situations we buy through most often.</p>
      </div>
      <div class="sits">
        <a class="sit" href="/sell-house-as-is"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>House needs repairs</a>
        <a class="sit" href="/stop-foreclosure"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>Facing foreclosure</a>
        <a class="sit" href="/sell-inherited-house"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>Inherited or probate</a>
        <div class="sit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>Relocating fast</div>
        <div class="sit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>Tired of tenants</div>
        <div class="sit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21s-7-4.35-9.5-8.5A5.5 5.5 0 0 1 12 6a5.5 5.5 0 0 1 9.5 6.5C19 16.65 12 21 12 21z"/><line x1="3" y1="3" x2="21" y2="21"/></svg>Going through divorce</div>
        <div class="sit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><line x1="3" y1="14" x2="21" y2="14"/></svg>Vacant property</div>
        <div class="sit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>Behind on payments</div>
      </div>
      <p class="sits-note">Don't see yours? <a href={site.phoneHref} data-track="call">Call or text {site.phone}</a>. We have probably bought through it before. You can also <a href={site.smsHref} data-track="text">send us a quick text</a> with your address.</p>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="band band--cream">
    <div class="wrap">
      <Reviews />
      <p class="sits-note" style="text-align:center"><a href="/testimonials">Read more seller stories &rarr;</a></p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="band band--surface">
    <div class="wrap">
      <div class="sec-head center">
        <span class="eyebrow">Questions sellers ask</span>
        <h2>Straight answers about selling fast for cash</h2>
      </div>
      <div class="faq">
        {coreFaqs.map((f, i) => (
          <details open={i === 0}>
            <summary>{f.q}<svg class="pm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
      <p class="sits-note" style="text-align:center"><a href="/faq">See all frequently asked questions &rarr;</a> or check the <a href="/areas-we-serve">areas we serve &rarr;</a></p>
    </div>
  </section>

  <OfferBand source="NextKey Site - Sell My House Fast" />
</Base>
