---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import OfferBand from '../components/OfferBand.astro';
import { coreFaqs } from '../data/faqs.js';
import { faqSchema } from '../lib/schema.js';
import { site } from '../data/site.js';

const title = 'How It Works: Sell Your House in 3 Steps | NextKey Home Offer';
const description = 'See how selling your Bay Area house to NextKey works: tell us about it, get a cash offer in about 24 hours, and close at a local title company on your date.';

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'How It Works', path: '/how-it-works' },
];

// Trimmed FAQ for this page (3 of the core set). The faqSchema below must match
// exactly what is rendered in the .faq block.
const pageFaqs = [coreFaqs[1], coreFaqs[2], coreFaqs[3]];

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to sell your house fast to NextKey',
  description:
    'A three-step cash sale: tell NextKey about your house, get a written cash offer in about 24 hours, and close at a local Bay Area title company on the date you choose.',
  step: [
    {
      '@type': 'HowToStep',
      name: 'Tell us about your house',
      text: 'Share the address and a few basic details by form, phone, or text. It takes about two minutes and there is no obligation.',
    },
    {
      '@type': 'HowToStep',
      name: 'Get your cash offer in about 24 hours',
      text: 'We review recent Bay Area sales and your home’s condition, then send a real, no-obligation cash offer in writing, typically within 24 hours.',
    },
    {
      '@type': 'HowToStep',
      name: 'Pick your date and get paid',
      text: 'Choose any closing date that works for you. We close at a local title company in as few as 7 days and you walk away with cash.',
    },
  ],
};
---
<Base title={title} description={description} schema={[howToSchema, faqSchema(pageFaqs)]}
  ogTitle="How Selling Your House to NextKey Works"
  ogDescription="Three simple steps to a cash sale in the Bay Area: tell us about your house, get a written offer in about 24 hours, and close on your date.">

  <section class="subhero">
    <div class="subhero__in">
      <span class="eyebrow subhero__eyebrow">The process · Start to finish</span>
      <h1>How Selling Your House to NextKey Works</h1>
      <p>Three steps, no agents, no repairs, and no guesswork. From your first message to cash in hand, here is exactly what happens, how long each part takes, and what you need on hand.</p>
      <div class="subhero__cta">
        <a class="btn btn--primary btn--lg" href="#offer">Get my cash offer</a>
        <a class="btn btn--ghost btn--lg" href={site.phoneHref} data-track="call">Call or text {site.phone}</a>
      </div>
    </div>
  </section>
  <Breadcrumbs items={crumbs} />

  <!-- DETAILED 3 STEPS -->
  <section class="band band--dark" id="the-steps">
    <div class="wrap">
      <div class="sec-head center">
        <span class="eyebrow">The three steps</span>
        <h2>From your address to cash, in plain English</h2>
        <p>No realtor, no listing, no spam. Here is what each step actually involves.</p>
      </div>
      <div class="steps">
        <div class="step">
          <div class="step__n">Step 01</div>
          <h3>Tell us about your house</h3>
          <p>Send us the address and a few quick details by form, phone, or text. We ask about the basics: rough condition, whether anyone is living there, and your timeline. There is nothing to prepare and nothing to clean. It takes about two minutes, costs nothing, and puts you under no obligation. If it is easier to talk it through, call or text {site.phone} and a real person answers.</p>
        </div>
        <div class="step">
          <div class="step__n">Step 02</div>
          <h3>Get your cash offer in about 24 hours</h3>
          <p>We look at recent sales near you, the condition of your home, and what it would take to get it market-ready, then make a fair cash number. Most offers go out within one business day, in writing, with no obligation to accept. We buy with our own funds, so there is no bank, no appraisal, and no financing contingency to fall through. Want to see we are for real? We will show proof of funds on request.</p>
        </div>
        <div class="step">
          <div class="step__n">Step 03</div>
          <h3>Pick your date and get paid</h3>
          <p>If the number works, you choose the closing date. Need to be out in a week? We can close in as few as 7 days. Need 60 or 90 days to line up your next place? That works too. We close at a reputable local title company, a licensed professional handles the paperwork, and you walk away with cash. No fees, no commissions, and we cover standard closing costs.</p>
        </div>
      </div>
      <div class="steps-cta"><a class="btn btn--primary btn--lg" href="#offer">Start with your address</a> <a class="btn btn--ghost btn--lg" href="/sell-my-house-fast">See why sellers choose cash</a></div>
    </div>
  </section>

  <!-- WHAT TO EXPECT -->
  <section class="band band--surface" id="what-to-expect">
    <div class="wrap">
      <div class="sec-head center">
        <span class="eyebrow">What to expect</span>
        <h2>What you can count on at every step</h2>
        <p>The same straight talk and real proof from the first call to the closing table.</p>
      </div>
      <div class="grid grid--2">
        <article class="card">
          <div class="card__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/></svg></div>
          <h3>A written cash offer</h3>
          <p>You get your number in writing with no obligation. Accept it, sit on it, or walk away. We do not chase you and we do not pressure you.</p>
        </article>
        <article class="card">
          <div class="card__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l1.9 4.6L18 9l-4.1 1.4L12 15l-1.9-4.6L6 9l4.1-1.4z"/><path d="M5 15l.8 2.2L8 18l-2.2.8L5 21l-.8-2.2L2 18l2.2-.8z"/></svg></div>
          <h3>White-glove service</h3>
          <p>One team handles the details from the first call to closing. You get a single point of contact, not a runaround or a rotating cast of strangers.</p>
        </article>
        <article class="card">
          <div class="card__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m7.5 4.3 9 5.1"/><path d="M21 8a2 2 0 0 0-1-1.7l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.7l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg></div>
          <h3>Transition resources</h3>
          <p>Need movers, storage, or help finding your next place? We point you to our trusted local resources so the move is handled with care, not chaos.</p>
        </article>
        <article class="card">
          <div class="card__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="22" x2="21" y2="22"/><polygon points="12 2 21 7 3 7"/><line x1="5" y1="10" x2="5" y2="18"/><line x1="10" y1="10" x2="10" y2="18"/><line x1="14" y1="10" x2="14" y2="18"/><line x1="19" y1="10" x2="19" y2="18"/></svg></div>
          <h3>A local title-company closing</h3>
          <p>We close at a reputable Bay Area title company, so a licensed professional handles the paperwork and the money is real and verified.</p>
        </article>
      </div>
      <p class="sits-note">Every offer is no-obligation. Closing timelines vary by property and title.</p>
    </div>
  </section>

  <!-- TIMELINE / REASSURANCE -->
  <section class="band band--cream" id="timeline">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow">The timeline</span>
        <h2>How fast this can actually move</h2>
        <p>A traditional listing in the Bay Area can take months once you add repairs, showings, inspections, and a buyer's loan. Our path is shorter and the dates are yours to set.</p>
      </div>
      <div class="grid grid--3">
        <article class="card">
          <div class="card__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
          <h3>Day one</h3>
          <p>You reach out and tell us about the house. We confirm the details and start working on your number that same day.</p>
        </article>
        <article class="card">
          <div class="card__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="m9 15 2 2 4-4"/></svg></div>
          <h3>About 24 hours</h3>
          <p>Your written, no-obligation cash offer lands. We walk you through how we got to the number so nothing is a mystery.</p>
        </article>
        <article class="card">
          <div class="card__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><polyline points="9 15 11 17 15 13"/></svg></div>
          <h3>As few as 7 days</h3>
          <p>Once you accept, we can close in about a week, or whenever you want. You set the date and walk away with cash.</p>
        </article>
      </div>
      <p class="sits-note">A note on fairness: NextKey is a local cash buyer, not a brokerage, and we do not give legal or tax advice. We will always tell you straight whether selling to us actually makes sense for your situation. Curious what real sellers say? <a href="/testimonials">Read their stories &rarr;</a></p>
    </div>
  </section>

  <!-- TRIMMED FAQ -->
  <section class="band band--surface" id="faq">
    <div class="wrap">
      <div class="sec-head center">
        <span class="eyebrow">Common questions</span>
        <h2>Quick answers about the process</h2>
      </div>
      <div class="faq">
        {pageFaqs.map((f, i) => (
          <details open={i === 0}>
            <summary>{f.q}<svg class="pm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
      <p class="sits-note" style="text-align:center"><a href="/faq">See all frequently asked questions &rarr;</a></p>
    </div>
  </section>

  <OfferBand source="NextKey Site - How It Works" />
</Base>
